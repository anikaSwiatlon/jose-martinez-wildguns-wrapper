{
  "manifest_version": 3,
  "name": "Jose Martinez Wildguns Helper",
  "version": "0.2.0",
  "description": "Reads city guard unit summaries from Wildungs and saves them to your database.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://*.wildungs.com/*",
    "https://*.wildguns.gameforge.com/*",
    "https://*.supabase.co/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.wildungs.com/*",
        "https://*.wildguns.gameforge.com/*"
      ],
      "js": ["features/unit-reader/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["features/market-offers/marketOffers.js"],
      "matches": [
        "https://*.wildungs.com/*",
        "https://*.wildguns.gameforge.com/*"
      ]
    }
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
  "gecko": {
    "id": "@addon-example",
    "strict_min_version": "58.0"
  }
}
}
